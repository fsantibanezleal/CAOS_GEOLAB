# GeoLab is a static, client-side app (ADR-0059) — it needs NO secrets to run.
# Secrets, if ever needed, live ONLY in _CAOS_MANAGE/credentials/ (never committed here).
# Copy to `.env` for local overrides.

# Base path for the deployed app (GitHub Pages project sites serve under /<repo>/).
# Dev: "/". Pages project site: "/CAOS_GEOLAB/". Custom domain (geolab.fasl-work.com): "/".
VITE_BASE_URL=/

# Optional: a base URL for sample datasets / COG/STAC catalogs (defaults to bundled public/data).
VITE_SAMPLE_DATA_URL=
